# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# SQLite location (mount as volume in Docker / Railway)
DATABASE_PATH=./data/resend_rapper.sqlite

# Master key for encrypting sensitive settings (Resend API key etc.)
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=replace-me-with-64-hex-chars

# Session secret for the admin web UI
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-64-hex-chars

# Optional: pre-seed Resend API key on first boot
# RESEND_API_KEY=re_xxx
