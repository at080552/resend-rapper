# --- REQUIRED ---

# Master key for encrypting Resend API keys at rest. Must be >= 32 chars and
# NOT a placeholder (the app will refuse to start if it looks dev-ish).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# Session secret for the admin web UI. Same generation rule.
SESSION_SECRET=

# --- OPTIONAL ---

# HTTP listen
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# SQLite location (mount as a volume in Docker / Railway)
DATABASE_PATH=/data/resend_rapper.sqlite

# Pre-seed Resend API key on first boot (otherwise set it via the admin UI)
# RESEND_API_KEY=re_xxx

# Trust X-Forwarded-* headers when running behind a TLS-terminating proxy.
# Required for accurate IP-based rate limiting and audit logs in that case.
TRUST_PROXY=false

# Hard cap for inbound request bodies (bytes). Default 10MB.
MAX_BODY_BYTES=10485760

# Extra origins permitted for the admin UI cross-origin requests
# (comma separated). Same-origin always works.
# ADMIN_ORIGINS=https://admin.example.com
